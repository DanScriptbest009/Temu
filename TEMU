local hideConnections = {}
local function hideOpenButton()
    local coreGui = game:GetService("CoreGui")
    local function findRayfield()
        for _, child in ipairs(coreGui:GetChildren()) do
            if child:FindFirstChild("Rayfield") then return child.Rayfield end
        end
        return nil
    end
    local rayfield = findRayfield()
    if not rayfield then
        Rayfield:Notify({Title = "Error", Content = lang.RayfieldError, Duration = 3})
        return
    end
    for _, conn in ipairs(hideConnections) do conn:Disconnect() end
    hideConnections = {}
    local function hidePrompt(prompt)
        if not prompt or not prompt:FindFirstChild("Title") then return end
        prompt.Title.Visible = false
        prompt.BackgroundTransparency = 1
        table.insert(hideConnections, prompt.Title:GetPropertyChangedSignal("Visible"):Connect(function()
            if prompt.Title.Visible then prompt.Title.Visible = false end
        end))
        table.insert(hideConnections, prompt:GetPropertyChangedSignal("BackgroundTransparency"):Connect(function()
            if prompt.BackgroundTransparency ~= 1 then prompt.BackgroundTransparency = 1 end
        end))
    end
    local prompt = rayfield:FindFirstChild("Prompt")
    if prompt then hidePrompt(prompt) end
    table.insert(hideConnections, rayfield.ChildAdded:Connect(function(child)
        if child.Name == "Prompt" then hidePrompt(child) end
    end))
end

local function showOpenButton()
    for _, conn in ipairs(hideConnections) do conn:Disconnect() end
    hideConnections = {}
    local coreGui = game:GetService("CoreGui")
    local function findRayfield()
        for _, child in ipairs(coreGui:GetChildren()) do
            if child:FindFirstChild("Rayfield") then return child.Rayfield end
        end
        return nil
    end
    local rayfield = findRayfield()
    if not rayfield then return end
    local prompt = rayfield:FindFirstChild("Prompt")
    if prompt then
        prompt.BackgroundTransparency = 0
        if prompt:FindFirstChild("Title") then
            prompt.Title.Visible = true
        end
    end
end

