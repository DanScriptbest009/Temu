local function Shoot2Die(ignoreSlide)
    if not Shoot2DieEnabled and not ignoreSlide then return end
    local target = GetClosestEnemyByMouse()
    if not target then return end
    if Shoot2DieToClick2Die then
        PerformKnifeKill(target)
        if not ignoreSlide then
            Rayfield:Notify({Title = lang.Click2DieTitle, Content = string.format(lang.Click2DieContent, target.Name), Duration = 2})
        end
        return
    end
    PerformKnifeKill(target)
    local Tool, KillRemote = GetToolWithKill()
    if KillRemote and Tool and Tool:FindFirstChild("Handle") then
        local direction = (target.Character.HumanoidRootPart.Position - Tool.Handle.Position).Unit
        for _ = 1, 5 do pcall(function() KillRemote:FireServer(target, direction) end) end
    end
    local Eq, GunTool = HasWeaponEquipped()
    if not Eq and AutoEquipEnabled then GunTool = EquipGun() end
    if GunTool then
        local pos = GetPredictedPosition(target)
        if pos then for _ = 1, 3 do Shoot(target, pos) end end
    end
    if not ignoreSlide then
        Rayfield:Notify({Title = lang.Shoot2DieTitle, Content = string.format(lang.Shoot2DieContent, target.Name), Duration = 2, Image = "target"})
    end
end

local function KillTarget(Enemy)
    if not Enemy then return false end
    local TargetCharacter = Enemy.Character
    if not TargetCharacter then return false end
    local TargetHumanoidRootPart = TargetCharacter:FindFirstChild("HumanoidRootPart")
    if not TargetHumanoidRootPart then return false end
    local Tool, Kill = GetToolWithKill()
    if KnifeKill then pcall(function() KnifeKill:FireServer(Enemy, Enemy) end) end
    if Kill then
        local Direction = CFrame.lookAt(Tool and Tool:FindFirstChild("Handle") and Tool.Handle.Position or Vector3.new(0,0,0), TargetHumanoidRootPart.Position).LookVector
        pcall(function() Kill:FireServer(Enemy, Direction) end)
    end
    return true
end

local function KillTargetWithGun(Enemy)
    if not Enemy then return false end
    local Pos = GetPredictedPosition(Enemy)
    if not Pos then return false end
    local Eq, Tool = HasWeaponEquipped()
    if not Eq then
        if AutoEquipEnabled then Tool = EquipGun() if not Tool or Tool.Parent ~= LocalPlayer.Character then return false end
        else return false end
    end
    Shoot(Enemy, Pos)
    if AutoUnEquipEnabled and not Eq then
        task.delay(0.008, function()
            if CurrentGun and CurrentGun.Parent == LocalPlayer.Character then UnequipGun() end
        end)
    end
    return true
end

