local function GiveCloak()
    if CloakTool and CloakTool.Parent and CloakTool:IsDescendantOf(LocalPlayer) then
        Rayfield:Notify({Title = "Cloak", Content = lang.AlreadyHaveCloak, Duration = 2})
        return
    end
    local Tool = Instance.new("Tool")
    Tool.Name = "Desync (NOT real desync)"
    Tool.RequiresHandle = false
    Tool.Parent = LocalPlayer.Backpack
    CloakTool = Tool
    local Active = false
    local RealHRP, FakeHRP, Humanoid, Loop
    local SPEED = CloakSpeed
    local ACCEL = CloakAccel
    local Velocity = Vector3.zero
    Tool.Equipped:Connect(function()
        if Active then return end
        Active = true
        local Character = LocalPlayer.Character
        if not Character then return end
        Humanoid = Character:FindFirstChildOfClass("Humanoid")
        RealHRP = Character:FindFirstChild("HumanoidRootPart")
        if not Humanoid or not RealHRP then return end
        FakeHRP = CreateFakePart(RealHRP)
        RealHRP.Anchored = true
        RealHRP.CFrame = FAR
        Camera.CameraSubject = FakeHRP
        Loop = RunService.RenderStepped:Connect(function(dt)
            if Active and RealHRP then
                RealHRP.CFrame = FAR
                RealHRP.AssemblyLinearVelocity = Vector3.zero
                RealHRP.AssemblyAngularVelocity = Vector3.zero
            end
            local cam = Camera.CFrame
            local look = cam.LookVector
            local right = cam.RightVector
            local up = cam.UpVector
            local move = Control:GetMoveVector()
            local dir = Vector3.zero
            if move.Z < 0 then dir += look elseif move.Z > 0 then dir -= look end
            if move.X > 0 then dir += right elseif move.X < 0 then dir -= right end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += up end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= up end
            local targetVelocity = dir.Magnitude > 0 and dir.Unit * SPEED or Vector3.zero
            Velocity = Velocity:Lerp(targetVelocity, math.clamp(dt * ACCEL, 0, 1))
            local targetPos = FakeHRP.Position + Velocity
            FakeHRP.CFrame = FakeHRP.CFrame:Lerp(CFrame.new(targetPos, targetPos + cam.LookVector), math.clamp(dt * 6, 0, 1))
        end)
    end)
    Tool.Unequipped:Connect(function()
        Active = false
        if Loop then Loop:Disconnect() end
        if Humanoid then Camera.CameraSubject = Humanoid end
        if RealHRP and FakeHRP then
            RealHRP.Anchored = false
            local pos = FakeHRP.Position
            pos = Vector3.new(changePos(pos.X), changePos(pos.Y), changePos(pos.Z))
            RealHRP.CFrame = CFrame.new(pos) * (FakeHRP.CFrame - FakeHRP.Position)
            RealHRP.AssemblyLinearVelocity = Vector3.zero
            RealHRP.AssemblyAngularVelocity = Vector3.zero
        end
        if FakeHRP then FakeHRP:Destroy() end
    end)
    Rayfield:Notify({Title = "Cloak", Content = lang.GiveCloak, Duration = 2})
end

