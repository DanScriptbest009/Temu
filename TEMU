local KnifeKillRemote = cloneref(
    game:GetService("ReplicatedStorage")
        .Packages
        .Networking["RE/Combat/Knifekill"]
)
local InstaActive = false
local InstaConnections = {}
local InstaThreads = {}

local function FireKill()
    local enemies = GetEnemyNamesFromFrames()
    if #enemies == 0 then return end
    for _, name in ipairs(enemies) do
        local plr = Players:FindFirstChild(name)
        if plr and KnifeKillRemote then
            pcall(function() KnifeKillRemote:FireServer(plr, plr.Character or plr) end)
        end
    end
end

local function StopInstaKill()
    for _, c in ipairs(InstaConnections) do c:Disconnect() end
    InstaConnections = {}
    for _, t in ipairs(InstaThreads) do task.cancel(t) end
    InstaThreads = {}
    InstaActive = false
end

local function StartInstaKill()
    if not KnifeKillRemote then return end
    StopInstaKill()
    InstaActive = true
    local function b(e)
        table.insert(InstaConnections, e:Connect(FireKill))
    end
    b(RunService.Heartbeat)
    b(RunService.RenderStepped)
    b(RunService.Stepped)
    for _ = 1, 5 do
        table.insert(InstaThreads, task.spawn(function() while InstaActive do FireKill() task.wait() end end))
    end
    for _ = 1, 3 do
        table.insert(InstaThreads, task.spawn(function() while InstaActive do FireKill() RunService.Heartbeat:Wait() end end))
    end
end

