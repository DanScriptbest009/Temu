local function missing(name, replacement)
    local env = getgenv()
    if env[name] ~= nil then return env[name] end
    if replacement ~= nil then env[name] = replacement return replacement end
    return nil
end

local cloneref = missing("cloneref", function(obj)
    if obj:IsA("Service") then return game:GetService(obj.Name) end
    return obj
end)

local writefile = missing("writefile", function(file, data, safe)
    if safe then return pcall(writefile, file, data) end
    writefile(file, data)
end)
local readfile = missing("readfile", function(file, safe)
    if safe then return pcall(readfile, file) end
    return readfile(file)
end)
local isfile = missing("isfile", function(file)
    local s, r = pcall(readfile, file)
    return s and r ~= nil and r ~= ""
end)
