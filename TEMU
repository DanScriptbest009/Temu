local function Shoot(Target, Pos)
    local Character = LocalPlayer.Character
    if not Character then return false end
    for _, Tool in ipairs(Character:GetChildren()) do
        if Tool:IsA("Tool") then
            local Fire = Tool:FindFirstChild("fire") or Tool:FindFirstChild("Fire")
            if Fire then
                local HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
                if not HumanoidRootPart then return false end
                local Handle = Tool:FindFirstChild("Handle") or Tool
                local Beam = ReplicatedStorage:FindFirstChild("LocalBeam")
                local Show = Tool:FindFirstChild("showBeam")
                local Kill = Tool:FindFirstChild("kill") or Tool:FindFirstChild("Kill")
                pcall(function() Fire:FireServer() end)
                if Beam then pcall(function() Beam:Fire(Handle, Pos) end) end
                if Show then pcall(function() Show:FireServer(Pos, HumanoidRootPart.Position, Handle) end) end
                if Kill then pcall(function() Kill:FireServer(Target, (Pos - HumanoidRootPart.Position).Unit, HumanoidRootPart.Position) end) end
                if NotifyWhereShooted then
                    Rayfield:Notify({Title = lang.ShootingNotify, Content = lang.ShootPosContent .. tostring(Pos), Duration = 2, Image = "target"})
                end
                return true
            end
        end
    end
    return false
end

local function FastFireTarget(forceTarget)
    if not AutoShootEnabled then return end
    local Target = forceTarget or GetClosestPlayer()
    if not Target then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    if not AllowShootingWhereYouDontLooking and not LookingEnemy(Target) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    if not IfISeeTarget(Target) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local Pos = GetPredictedPosition(Target)
    if not Pos then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local Eq, Tool = HasWeaponEquipped()
    if not Eq then
        if AutoEquipEnabled then
            Tool = EquipGun()
            if not Tool or Tool.Parent ~= LocalPlayer.Character then return end
        else
            if AutoUnEquipEnabled then UnequipGun() end
            return
        end
    end
    Shoot(Target, Pos)
    LastShot = tick()
    if AutoUnEquipEnabled then
        task.delay(0.008, function()
            if CurrentGun and CurrentGun.Parent == LocalPlayer.Character then
                UnequipGun()
            end
        end)
    end
end

